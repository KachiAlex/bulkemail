# Example environment variables (COPY and fill values, do NOT commit secrets)

# Postgres
DATABASE_URL=postgres://user:password@db-host:5432/dbname

# Cloudinary (if used)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# JWT (backend auth)
JWT_SECRET=replace-with-strong-random-secret

# Server
NODE_ENV=production
PORT=3000

# (Legacy) Firebase service account base64 (keep until Firebase removed)
FIREBASE_SERVICE_ACCOUNT_B64=

# Vite client env (if still using Firebase during migration)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
