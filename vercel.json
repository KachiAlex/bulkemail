{
  "buildCommand": "cd frontend && npm run build && cd ..",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install && cd frontend && npm install",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://pandicrm.onrender.com/api/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|ico|svg))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "/api",
    "VITE_API_TIMEOUT_MS": "30000",
    "NODE_ENV": "production",
    "BUILD_TIMESTAMP": "2025-04-06-15-50"
  }
}
